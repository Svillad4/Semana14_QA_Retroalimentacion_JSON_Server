{
  "name": "semana14-qa-retroalimentacion-json-server",
  "version": "1.0.0",
  "description": "Actividad Semana 14: QA, retroalimentacion entre pares y plan de mejora con Vite y JSON Server.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "db": "json-server --watch db.json --port 3001",
    "start": "concurrently \"npm run db\" \"npm run dev\"",
    "check": "node scripts/qa-check.mjs",
    "reset-db": "node scripts/reset-db.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-basic-ssl": "latest",
    "bootstrap": "latest",
    "bootstrap-icons": "latest",
    "chart.js": "latest",
    "sweetalert2": "latest"
  },
  "devDependencies": {
    "concurrently": "latest",
    "json-server": "latest",
    "vite": "latest"
  },
  "keywords": [
    "qa",
    "json-server",
    "vite",
    "usabilidad",
    "accesibilidad",
    "optimizacion"
  ],
  "author": "Actividad academica Semana 14",
  "license": "MIT"
}
